DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Set DB_ENGINE=postgres to use Postgres (e.g. via Docker). Leave unset for sqlite.
DB_ENGINE=postgres
DB_NAME=weather_db
DB_USER=weather_user
DB_PASSWORD=weather_pass
DB_HOST=db
DB_PORT=5432

# Leave REDIS_URL blank for local dev without Docker (uses in-memory cache instead).
# Set it (e.g. redis://redis:6379/1) when running via docker-compose or with Redis installed.
REDIS_URL=
WEATHER_CACHE_TTL_SECONDS=600

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

OPENWEATHERMAP_API_KEY=
WEATHERAPI_API_KEY=
TOMORROW_IO_API_KEY=

ANTHROPIC_API_KEY=
